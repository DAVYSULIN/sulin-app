<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Todo el tráfico de la app viaja por HTTPS (Netlify + Supabase),
         por lo que no se permite tráfico sin cifrar (cleartext). -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
